# Name of the column in data/dataset.csv that the model predicts.
TARGET_COLUMN=Churn

# Learning task: either "classification" or "regression".
TASK_TYPE=classification

# Wall clock time budget handed to the FLAML AutoML search, in seconds.
AUTOML_TIME_BUDGET_SECONDS=60

# Filesystem path where the trained model is written and loaded from.
MODEL_OUTPUT_PATH=./models/model.pkl
